{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "response.schema.json",
  "title": "DeepSeek Cowork Response",
  "type": "object",
  "$defs": {
    "relative_posix_path": {
      "type": "string",
      "pattern": "^(?!/)(?!.*//)(?!.*\\\\)(?![A-Za-z]:)(?!.*(?:^|/)(?:\\.{1,2})(?:/|$))(?!.*\/$).+$"
    }
  },
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "protocol_version",
        "status",
        "summary",
        "files",
        "assumptions",
        "verification_notes"
      ],
      "properties": {
        "protocol_version": {
          "const": "2.0"
        },
        "status": {
          "const": "files"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "content"],
            "properties": {
              "path": {
                "$ref": "#/$defs/relative_posix_path"
              },
              "content": {
                "type": "string"
              }
            }
          }
        },
        "assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verification_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol_version", "status", "summary", "missing_context"],
      "properties": {
        "protocol_version": {
          "const": "2.0"
        },
        "status": {
          "const": "blocked"
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "missing_context": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/relative_posix_path"
          }
        }
      }
    }
  ]
}
